# ──────────────────────────────────────────────
# Database (used by the consuming application)
# ──────────────────────────────────────────────
DB_CONNECTION=sqlite
# DB_HOST=localhost
# DB_PORT=3306
# DB_DATABASE=cacheer_db
# DB_USERNAME=root
# DB_PASSWORD=

# ──────────────────────────────────────────────
# Redis (used by the consuming application)
# ──────────────────────────────────────────────
REDIS_CLIENT=
REDIS_HOST=localhost
REDIS_PASSWORD=
REDIS_PORT=6379
REDIS_NAMESPACE=

# ──────────────────────────────────────────────
# Cacheer Monitor
# ──────────────────────────────────────────────

# Path to the JSONL events file (absolute or relative to project root).
# Default: sys_get_temp_dir() . '/cacheer-monitor.jsonl'
CACHEER_MONITOR_EVENTS=

# If set, destructive API actions (clear, cleanup) require this token
# via the X-Monitor-Token header.
CACHEER_MONITOR_TOKEN=

# Enable value capture in events (true/false).
# Default: false
CACHEER_MONITOR_CAPTURE_VALUES=false

# SSE stream connection timeout in seconds.
# Default: 30
CACHEER_MONITOR_STREAM_TIMEOUT=30

# Max bytes for value preview JSON.
# Default: 2048
CACHEER_MONITOR_PREVIEW_BYTES=2048

# Comma-separated list of additional field names to redact in value previews.
# Built-in redacted keys: password, passwd, pwd, secret, token, access_token,
# refresh_token, authorization, api_key, apikey, private_key, client_secret,
# cookie, session
CACHEER_MONITOR_REDACT_KEYS=
