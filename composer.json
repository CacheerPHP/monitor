{
  "name": "cacheerphp/monitor",
  "description": "Dashboard and telemetry reporter for CacheerPHP.",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": ">=8.1",
    "silviooosilva/cacheer-php": "^4.7 || ^5.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0 || ^11.0 || ^12.0"
  },
  "autoload": {
    "psr-4": {
      "Cacheer\\Monitor\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Cacheer\\Monitor\\Tests\\": "Tests/"
    }
  },
  "bin": [
    "bin/cacheer-monitor"
  ],
  "scripts": {
    "test": "phpunit"
  }
}
